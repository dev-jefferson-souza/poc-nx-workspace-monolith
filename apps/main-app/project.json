{
  "name": "main-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "poc-nx-workspace-monolith",
  "sourceRoot": "apps/main-app/src",
  "tags": [],

  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/main-app",
        "index": "apps/main-app/src/index.html",
        "browser": "apps/main-app/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/main-app/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          "apps/main-app/src/favicon.ico",
          "apps/main-app/src/assets",
          {
            "glob": "**/*",
            "input": "libs/shared/i18n/src/lib/assets",
            "output": "assets/i18n"
          }
        ],
        "scripts": [],
        "styles": [
          "tools/styles/styles.scss",
          { "input": "tools/styles/_theme-dark.css", "bundleName": "theme-dark", "inject": false },
          { "input": "tools/styles/_theme-light.css", "bundleName": "theme-light", "inject": false }
        ]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "2kb",
              "maximumError": "4kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "main-app:build:production"
        },
        "development": {
          "buildTarget": "main-app:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "main-app:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/main-app/jest.config.ts"
      }
    }
  }
}
